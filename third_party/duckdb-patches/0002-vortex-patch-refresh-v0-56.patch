From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: pg_duckdb downstream
Date: Thu, 24 Apr 2026 00:00:00 +0000
Subject: [PATCH] vortex: refresh pass-variable-through-cmake-not-make.patch
 for v0.56.0

The upstream vortex_extension tag bundled with DuckDB v1.5.2 is v0.56.0,
which dropped cmake_policy(SET CMP0135 NEW) and bumped the CXX standard
from 20 back to 17. The prior patch's hunk headers no longer match, so
pg_vortex builds fail during fetch-content patching. Regenerate the
CMakeLists hunk against v0.56.0; Makefile hunk is unchanged.
---
diff --git a/.github/patches/extensions/vortex/pass-variable-through-cmake-not-make.patch b/.github/patches/extensions/vortex/pass-variable-through-cmake-not-make.patch
index 292d157e97..474b5ab6ca 100644
--- a/.github/patches/extensions/vortex/pass-variable-through-cmake-not-make.patch
+++ b/.github/patches/extensions/vortex/pass-variable-through-cmake-not-make.patch
@@ -1,8 +1,8 @@
 diff --git a/CMakeLists.txt b/CMakeLists.txt
-index fd205af..5eaae5b 100644
+index 9f92376..20d6bf8 100644
 --- a/CMakeLists.txt
 +++ b/CMakeLists.txt
-@@ -6,6 +6,11 @@ cmake_policy(SET CMP0135 NEW)
+@@ -3,6 +3,11 @@ cmake_minimum_required(VERSION 3.22)
  set(TARGET_NAME vortex)
  project(${TARGET_NAME}_project)
  
@@ -11,9 +11,9 @@ index fd205af..5eaae5b 100644
 +    set(CMAKE_C_FLAGS "${CMAKE_C_FLAGS} -ftls-model=global-dynamic")
 +endif()
 +
- set(CMAKE_CXX_STANDARD 20)
- set(CMAKE_CXX_STANDARD_REQUIRED ON)
  set(CMAKE_EXPORT_COMPILE_COMMANDS ON)
+ set(CMAKE_CXX_STANDARD 17)
+ 
 diff --git a/Makefile b/Makefile
 index 3017d3f..808f019 100644
 --- a/Makefile
