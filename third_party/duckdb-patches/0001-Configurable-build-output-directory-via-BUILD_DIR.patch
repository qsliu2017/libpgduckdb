From c71068d71f69fb8e3e1b9751654bc3c9f197bd1b Mon Sep 17 00:00:00 2001
From: qsliu <qsliu2017@outlook.com>
Date: Wed, 22 Apr 2026 14:47:31 +0800
Subject: [PATCH] Configurable build output directory via BUILD_DIR

Adds a BUILD_DIR knob (default "build") to the top-level Makefile that
parameterizes every build/<type> reference -- debug, release,
bundle-library, extension_configuration, wasm_*, cldebug, clreldebug,
reldebug, relassert, amaldebug, tidy, docs, clangd. Existing invocations
are unaffected; parent projects embedding DuckDB can set BUILD_DIR (to
a relative or absolute path) to isolate their build tree from other
consumers sharing the same checkout.

The value is propagated through cmake as -DDUCKDB_BUILD_DIR=..., which
in turn emits a preprocessor define consumed by
ExtensionRepository::BUILD_{DEBUG,RELEASE}_REPOSITORY_PATH in
extension_install_info.hpp. This keeps the
'INSTALL ... FROM local_build_debug' / 'local_build_release' SQL syntax
resolving to the actual output tree rather than the previously-hardcoded
'./build/<type>/repository'.
---
 CMakeLists.txt                                |  10 ++
 Makefile                                      | 158 ++++++++++--------
 .../duckdb/main/extension_install_info.hpp    |  13 +-
 3 files changed, 105 insertions(+), 76 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 3246265235..a1ec9f8e44 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -26,6 +26,16 @@ find_package(Threads REQUIRED)
 
 set(DUCKDB_MODULE_BASE_DIR "${CMAKE_CURRENT_LIST_DIR}")
 
+# Build output tree name -- mirrors the Makefile's BUILD_DIR knob. Defaults
+# to "build" so existing invocations are unaffected. Parent projects
+# embedding DuckDB can override this (e.g. for per-consumer build isolation)
+# and the value is propagated as a compile definition so the `local_build_*`
+# extension-repository paths baked into the binary stay consistent.
+if(NOT DEFINED DUCKDB_BUILD_DIR)
+  set(DUCKDB_BUILD_DIR "build")
+endif()
+add_definitions(-DDUCKDB_BUILD_DIR=\"${DUCKDB_BUILD_DIR}\")
+
 set(CMAKE_EXPORT_COMPILE_COMMANDS ON)
 
 set(CMAKE_CXX_STANDARD "11" CACHE STRING "C++ standard to enforce")
diff --git a/Makefile b/Makefile
index fb6adb1d09..c99bf29499 100644
--- a/Makefile
+++ b/Makefile
@@ -4,9 +4,21 @@ all: release
 opt: release
 unit: unittest
 
+# BUILD_DIR -- output tree name for every target below. Defaults to `build`
+# so existing invocations produce the exact same layout (build/debug,
+# build/release, build/wasm_*, ...). Parent projects embedding DuckDB can
+# override this (e.g. BUILD_DIR=build-myproj, or an absolute path) to
+# isolate their build tree from other consumers sharing the same checkout.
+BUILD_DIR ?= build
+
+# Propagated as a compile definition so the `local_build_debug` /
+# `local_build_release` extension-repository paths baked into the binary
+# stay consistent with the Makefile override.
+CMAKE_VARS := -DDUCKDB_BUILD_DIR="${BUILD_DIR}"
+
 EXTENSION_CONFIG_STEP ?=
 ifdef USE_MERGED_VCPKG_MANIFEST
-	EXTENSION_CONFIG_STEP = build/extension_configuration/vcpkg.json
+	EXTENSION_CONFIG_STEP = ${BUILD_DIR}/extension_configuration/vcpkg.json
 endif
 
 GENERATOR ?=
@@ -306,7 +318,7 @@ ifneq ("${VCPKG_TARGET_TRIPLET}", "")
 	CMAKE_VARS_BUILD:=${CMAKE_VARS_BUILD} -DVCPKG_TARGET_TRIPLET='${VCPKG_TARGET_TRIPLET}'
 endif
 ifeq (${USE_MERGED_VCPKG_MANIFEST}, 1)
-	CMAKE_VARS:=${CMAKE_VARS} -DVCPKG_MANIFEST_DIR='${PROJ_DIR}build/extension_configuration'
+	CMAKE_VARS:=${CMAKE_VARS} -DVCPKG_MANIFEST_DIR='${PROJ_DIR}${BUILD_DIR}/extension_configuration'
 endif
 
 ifneq ("${LTO}", "")
